# PulseSync Backend Configuration

# ==========================================
# Database Configuration
# ==========================================
DATABASE_URL=sqlite:///./pulsesync.db

# ==========================================
# JWT Configuration
# ==========================================
SECRET_KEY=your-secret-jwt-key-change-this-in-production
ALGORITHM=HS256

# ==========================================
# SMS Provider Configuration
# ==========================================
# Options: "twilio", "fast2sms", or "demo" (for testing)
SMS_PROVIDER=demo

# ==========================================
# Twilio Configuration (if SMS_PROVIDER=twilio)
# ==========================================
# Get these from https://www.twilio.com/console
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ==========================================
# Fast2SMS Configuration (if SMS_PROVIDER=fast2sms)
# ==========================================
# Get this from https://www.fast2sms.com
# FAST2SMS_API_KEY=your_fast2sms_api_key

# ==========================================
# Application Configuration
# ==========================================
APP_NAME=PulseSync
APP_VERSION=1.0.0
DEBUG=True

# ==========================================
# CORS Configuration
# ==========================================
FRONTEND_URL=http://localhost:5173
